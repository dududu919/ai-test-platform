[
  {
    "id": "whitebox-001-user-duplicate-username",
    "module": "user-management",
    "priority": "high",
    "preconditions": [],
    "setup": [
      {
        "action": "db.truncate",
        "table": "users"
      },
      {
        "action": "db.insert",
        "table": "users",
        "data": {
          "id": 1,
          "username": "testuser",
          "password": "password123",
          "email": "test@example.com",
          "role": "viewer"
        }
      }
    ],
    "steps": [
      {
        "action": "api.request",
        "target": "/api/users",
        "method": "POST",
        "body": {
          "username": "testuser",
          "password": "newpass",
          "email": "another@example.com",
          "role": "admin"
        }
      }
    ],
    "assertions": [
      {
        "type": "api",
        "target": "/api/users",
        "expect": {
          "status": "409"
        }
      },
      {
        "type": "db",
        "table": "users",
        "where": {
          "username": "testuser"
        },
        "expect": {
          "email": "test@example.com",
          "role": "viewer"
        }
      }
    ],
    "risk": "high"
  },
